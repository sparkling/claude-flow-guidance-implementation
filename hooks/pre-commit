#!/bin/bash
# Pre-commit hook: run tests before every commit.
# Install: git config core.hooksPath hooks
#
# Runs the full vitest suite. If any test fails, the commit is blocked.

set -euo pipefail

echo "[pre-commit] Running tests..."

npx vitest run --reporter=dot 2>&1
if [ $? -ne 0 ]; then
  echo ""
  echo "  Tests failed. Fix before committing."
  echo ""
  exit 1
fi

echo "[pre-commit] OK — 365 tests passed"
