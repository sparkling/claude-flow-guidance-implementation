# ============================================================================
# UPSTREAM AGGREGATION: GuidanceControlPlane
# ============================================================================

cp:GuidanceControlPlane a gcfg:Aggregator ;
    rdfs:label "GuidanceControlPlane" ;
    rdfs:comment """Top-level facade. Composes 6 subsystems in constructor.
    Does NOT include: trust, proof, adversarial, conformance, evolution,
    authority, temporal, uncertainty, gateway, continue-gate, persistence,
    meta-governance, coherence, capabilities, wasm-kernel, generators,
    analyzer, hooks, memory-gate, artifacts, truth-anchors, ruvbot.""" ;
    gcfg:composes mod:compiler ;
    gcfg:composes mod:retriever ;
    gcfg:composes mod:gates ;
    gcfg:composes mod:ledger ;
    gcfg:composes mod:optimizer ;
    gcfg:composes mod:headless .

# --- ControlPlane constructor calls ---
cp:GuidanceControlPlane gcfg:instantiates fact:createCompiler ;
    gcfg:instantiates fact:createRetriever ;
    gcfg:instantiates fact:createGates ;
    gcfg:instantiates fact:createLedger ;
    gcfg:instantiates fact:createOptimizer .

# --- ControlPlane.initialize() call chain ---
meth:cpInitialize a gcfg:Method ;
    rdfs:label "GuidanceControlPlane.initialize()" ;
    gcfg:calls meth:compilerCompile ;
    gcfg:calls meth:retrieverLoadBundle ;
    gcfg:calls meth:gatesSetActiveRules .

meth:cpRetrieveForTask a gcfg:Method ;
    rdfs:label "GuidanceControlPlane.retrieveForTask()" ;
    gcfg:calls meth:retrieverRetrieve .

meth:cpEvaluateCommand a gcfg:Method ;
    rdfs:label "GuidanceControlPlane.evaluateCommand()" ;
    gcfg:calls meth:gatesEvaluateCommand .

meth:cpOptimize a gcfg:Method ;
    rdfs:label "GuidanceControlPlane.optimize()" ;
    gcfg:calls meth:optimizerRunCycle ;
    gcfg:calls meth:retrieverLoadBundle ;
    skos:note "Only runs if ledger has 10+ events" .

meth:cpStartRun a gcfg:Method ;
    rdfs:label "GuidanceControlPlane.startRun()" ;
    gcfg:calls meth:ledgerCreateEvent .

meth:cpFinalizeRun a gcfg:Method ;
    rdfs:label "GuidanceControlPlane.finalizeRun()" ;
    gcfg:calls meth:ledgerFinalizeEvent ;
    gcfg:calls meth:ledgerEvaluate .

# ============================================================================
# UPSTREAM AGGREGATION: createGuidanceHooks()
# ============================================================================

hook:createGuidanceHooks a gcfg:Aggregator ;
    rdfs:label "createGuidanceHooks()" ;
    rdfs:comment """Hook integration layer. Does NOT create a ControlPlane.
    Accepts 3 pre-instantiated components as parameters and wires them
    into 5 Claude Code hook points.""" ;
    gcfg:acceptsInjected mod:gates ;
    gcfg:acceptsInjected mod:retriever ;
    gcfg:acceptsInjected mod:ledger .

# --- Hook registrations and what they call ---
hook:preCommand a gcfg:Hook ;
    rdfs:label "preCommand hook" ;
    gcfg:calls meth:gatesEvaluateCommand .

hook:preToolUse a gcfg:Hook ;
    rdfs:label "preToolUse hook" ;
    gcfg:calls meth:gatesEvaluateToolUse .

hook:preEdit a gcfg:Hook ;
    rdfs:label "preEdit hook" ;
    gcfg:calls meth:gatesEvaluateEdit .

hook:preTask a gcfg:Hook ;
    rdfs:label "preTask hook" ;
    gcfg:calls meth:retrieverRetrieve .

hook:postTask a gcfg:Hook ;
    rdfs:label "postTask hook" ;
    gcfg:calls meth:ledgerLogEvent ;
    gcfg:calls meth:ledgerEvaluate ;
    gcfg:calls meth:ledgerFinalizeEvent .

# ============================================================================
# UPSTREAM: DeterministicToolGateway internal calls
# ============================================================================

cls:DeterministicToolGateway a gcfg:Class ;
    rdfs:label "DeterministicToolGateway" ;
    rdfs:comment "Wraps EnforcementGates + adds idempotency cache + schema + budget" ;
    gcfg:composes mod:gates ;
    gcfg:calls meth:gatesEvaluateToolUse .

# ============================================================================
# UPSTREAM: OptimizerLoop internal calls
# ============================================================================

cls:OptimizerLoop a gcfg:Class ;
    rdfs:label "OptimizerLoop" ;
    rdfs:comment "Rule promotion cycle. Reads from ledger." ;
    gcfg:calls meth:ledgerRankViolations ;
    gcfg:calls meth:ledgerComputeMetrics .

# ============================================================================
# UPSTREAM: HeadlessRunner internal calls
# ============================================================================

cls:HeadlessRunner a gcfg:Class ;
    rdfs:label "HeadlessRunner" ;
    rdfs:comment "Automated compliance testing. Optionally uses ledger." ;
    gcfg:calls meth:ledgerCreateEvent ;
    gcfg:calls meth:ledgerLogEvent ;
    gcfg:calls meth:ledgerEvaluate ;
    gcfg:calls meth:ledgerFinalizeEvent .

# ============================================================================
# UPSTREAM METHOD REFERENCES (targets of gcfg:calls)
# ============================================================================

meth:compilerCompile a gcfg:Method ; rdfs:label "compiler.compile()" .
meth:retrieverLoadBundle a gcfg:Method ; rdfs:label "retriever.loadBundle()" .
meth:retrieverRetrieve a gcfg:Method ; rdfs:label "retriever.retrieve()" .
meth:gatesSetActiveRules a gcfg:Method ; rdfs:label "gates.setActiveRules()" .
meth:gatesEvaluateCommand a gcfg:Method ; rdfs:label "gates.evaluateCommand()" .
meth:gatesEvaluateToolUse a gcfg:Method ; rdfs:label "gates.evaluateToolUse()" .
meth:gatesEvaluateEdit a gcfg:Method ; rdfs:label "gates.evaluateEdit()" .
meth:ledgerCreateEvent a gcfg:Method ; rdfs:label "ledger.createEvent()" .
meth:ledgerLogEvent a gcfg:Method ; rdfs:label "ledger.logEvent()" .
meth:ledgerFinalizeEvent a gcfg:Method ; rdfs:label "ledger.finalizeEvent()" .
meth:ledgerEvaluate a gcfg:Method ; rdfs:label "ledger.evaluate()" .
meth:ledgerRankViolations a gcfg:Method ; rdfs:label "ledger.rankViolations()" .
meth:ledgerComputeMetrics a gcfg:Method ; rdfs:label "ledger.computeMetrics()" .
meth:optimizerRunCycle a gcfg:Method ; rdfs:label "optimizer.runCycle()" .

# ============================================================================
# OUR WRAPPER: Files and their upstream usage
# ============================================================================

wrap:phase1Runtime a gcfg:WrapperFile ;
    rdfs:label "src/guidance/phase1-runtime.js" ;
    rdfs:comment """Creates GuidancePhase1Runtime. Instantiates 5 upstream factories
    in constructor, then wires them via createGuidanceHooks() in initialize().""" ;
    gcfg:instantiates fact:createCompiler ;
    gcfg:instantiates fact:createRetriever ;
    gcfg:instantiates fact:createGates ;
    gcfg:instantiates fact:createLedger ;
    gcfg:instantiates fact:createGuidanceHooks ;
    gcfg:importsModule mod:compiler ;
    gcfg:importsModule mod:retriever ;
    gcfg:importsModule mod:gates ;
    gcfg:importsModule mod:ledger ;
    gcfg:importsModule mod:hooks .

wrap:advancedRuntime a gcfg:WrapperFile ;
    rdfs:label "src/guidance/advanced-runtime.js" ;
    rdfs:comment """Creates GuidanceAdvancedRuntime. Composes phase1Runtime +
    6 additional upstream subsystems (conditionally, with null-object stubs).""" ;
    gcfg:composes wrap:phase1Runtime ;
    gcfg:instantiates fact:createTrustSystem ;
    gcfg:instantiates fact:createThreatDetector ;
    gcfg:instantiates fact:createCollusionDetector ;
    gcfg:instantiates fact:createMemoryQuorum ;
    gcfg:instantiates fact:createProofChain ;
    gcfg:instantiates fact:createConformanceRunner ;
    gcfg:instantiates fact:createEvolutionPipeline ;
    gcfg:importsModule mod:trust ;
    gcfg:importsModule mod:adversarial ;
    gcfg:importsModule mod:proof ;
    gcfg:importsModule mod:conformanceKit ;
    gcfg:importsModule mod:evolution .

wrap:memoryWriteGate a gcfg:WrapperFile ;
    rdfs:label "src/guidance/memory-write-gate.js" ;
    rdfs:comment """Wraps upstream MemoryWriteGate and adds semantic contradiction
    detection via cosine similarity on embeddings.""" ;
    gcfg:instantiates fact:createMemoryWriteGate ;
    gcfg:instantiates fact:createMemoryEntry ;
    gcfg:importsModule mod:memoryGate ;
    gcfg:composes wrap:embeddingProvider .

wrap:embeddingProvider a gcfg:WrapperFile ;
    rdfs:label "src/guidance/embedding-provider.js" ;
    rdfs:comment """Custom IEmbeddingProvider. Hash-based (deterministic, test) or
    AgentDB-backed (production). Does NOT import any upstream guidance module.""" ;
    skos:note "Zero upstream guidance imports. Uses agentdb optionally." .

wrap:enforcement a gcfg:WrapperFile ;
    rdfs:label "src/enforcement.cjs" ;
    rdfs:comment """Claude Code hook handler. Reads stdin JSON, dispatches to
    guidance-integrations.js via subprocess. Does NOT import any upstream
    guidance module directly.""" ;
    skos:note "Zero upstream guidance imports. Spawns subprocesses." .

wrap:integrationRunners a gcfg:WrapperFile ;
    rdfs:label "src/guidance/integration-runners.js" ;
    rdfs:comment """Integration test suites exercising the full runtime stack.
    6 runners: hooks, trust, adversarial, proof, conformance, evolution.""" ;
    gcfg:instantiates fact:createProofChain ;
    gcfg:importsModule mod:proof .

wrap:guidanceAutopilot a gcfg:WrapperFile ;
    rdfs:label "scripts/guidance-autopilot.js" ;
    rdfs:comment """Autonomous rule promotion pipeline. Analyzes CLAUDE.md,
    runs A/B benchmarks, promotes winning local rules.""" ;
    gcfg:instantiates fact:createCompiler ;
    gcfg:instantiates fact:analyze ;
    gcfg:instantiates fact:benchmark ;
    gcfg:instantiates fact:abBenchmark ;
    gcfg:importsModule mod:analyzer ;
    gcfg:importsModule mod:compiler .

wrap:codexBridge a gcfg:WrapperFile ;
    rdfs:label "scripts/guidance-codex-bridge.js" ;
    rdfs:comment """HTTP/CLI bridge. Spawns enforcement.cjs and optionally
    npx @claude-flow/cli hooks. Zero upstream guidance imports.""" ;
    skos:note "Zero upstream guidance imports. Spawns subprocesses." .

wrap:contentAwareExecutor a gcfg:WrapperFile ;
    rdfs:label "src/guidance/content-aware-executor.js" ;
    rdfs:comment """Synthetic executor for A/B benchmarking. Produces behavior
    differences based on CLAUDE.md content without calling real Claude.""" ;
    skos:note "Zero upstream guidance imports." .

# ============================================================================
# TRANSITIVE CALL ANALYSIS
# ============================================================================
#
# Q: What upstream modules does our wrapper TRANSITIVELY invoke?
#
# Starting from our entry points and following all call chains:
#
# wrap:advancedRuntime
#   -> (composes) wrap:phase1Runtime
#     -> (instantiates) createCompiler, createRetriever, createGates, createLedger
#     -> (instantiates) createGuidanceHooks
#       -> (internally calls) gates.evaluateCommand/ToolUse/Edit
#       -> (internally calls) retriever.retrieve
#       -> (internally calls) ledger.logEvent/evaluate/finalizeEvent
#   -> (instantiates) createTrustSystem
#   -> (instantiates) createThreatDetector, createCollusionDetector, createMemoryQuorum
#   -> (instantiates) createProofChain
#   -> (instantiates) createConformanceRunner
#   -> (instantiates) createEvolutionPipeline
#
# wrap:memoryWriteGate
#   -> (instantiates) createMemoryWriteGate
#   -> (instantiates) createMemoryEntry
#   -> (composes) embeddingProvider (no upstream guidance deps)
#
# wrap:guidanceAutopilot
#   -> (instantiates) createCompiler
#   -> (calls) analyze, benchmark, abBenchmark
#
# TOTAL UNIQUE UPSTREAM MODULES TRANSITIVELY REACHED: 12
#   compiler, retriever, gates, ledger, hooks,
#   trust, adversarial, proof, conformance-kit, evolution,
#   memory-gate, analyzer
#
# NEVER REACHED (20 modules):
#   gateway, continue-gate, persistence, temporal, uncertainty,
#   authority, meta-governance, optimizer, headless, wasm-kernel,
#   generators, capabilities, coherence, manifest-validator, artifacts,
#   truth-anchors, ruvbot-integration, types (implicit), crypto-utils
#
# Q: What does GuidanceControlPlane TRANSITIVELY invoke?
#
# cp:GuidanceControlPlane
#   -> (composes) compiler
#   -> (composes) retriever
#   -> (composes) gates
#   -> (composes) ledger
#   -> (composes) optimizer
#     -> (calls) ledger.rankViolations, ledger.computeMetrics
#   -> (composes) headless (optional)
#     -> (calls) ledger.createEvent/logEvent/evaluate/finalizeEvent
#
# TOTAL UNIQUE UPSTREAM MODULES IN CONTROLPLANE: 6
#   compiler, retriever, gates, ledger, optimizer, headless
#
# OVERLAP ANALYSIS (our wrapper vs ControlPlane):
#
#   Both use: compiler, retriever, gates, ledger  (4 modules)
#   Only ControlPlane uses: optimizer, headless    (2 modules)
#   Only our wrapper uses: hooks, trust, adversarial, proof,
#     conformance-kit, evolution, memory-gate, analyzer  (8 modules)
#
# KEY INSIGHT: Neither ControlPlane NOR our wrapper uses:
#   gateway, continue-gate, persistence, temporal, uncertainty,
#   authority, meta-governance, capabilities, coherence,
#   manifest-validator, artifacts, truth-anchors, wasm-kernel,
#   generators, ruvbot-integration
#   = 15 modules that are PURELY STANDALONE, used by NOBODY's aggregation
#
# The ControlPlane is NOT a super-aggregator that calls everything.
# It only aggregates 6 of 32 modules. The other 26 are standalone.

# ============================================================================
# COVERAGE SUMMARY
# ============================================================================

gcfg:coverageSummary a gcfg:Analysis ;
    rdfs:label "Module Coverage Summary" ;
    gcfg:totalUpstreamModules "32"^^xsd:integer ;
    gcfg:modulesUsedByWrapper "12"^^xsd:integer ;
    gcfg:modulesInControlPlane "6"^^xsd:integer ;
    gcfg:modulesUsedByBoth "4"^^xsd:integer ;
    gcfg:modulesOnlyControlPlane "2"^^xsd:integer ;
    gcfg:modulesOnlyWrapper "8"^^xsd:integer ;
    gcfg:modulesUsedByNeither "15"^^xsd:integer ;
    gcfg:modulesInternalOnly "3"^^xsd:integer ;
    skos:note """Corrected count: 12 modules (not 11 as previously stated).
    The autopilot script imports analyzer and compiler — analyzer was missed
    in earlier analysis. types and crypto-utils are internal-only modules,
    not meant to be directly consumed.

    The 15 unused modules are all standalone — they are not reachable
    through any aggregation layer. They must be individually instantiated
    and wired into the runtime by the consumer. Neither GuidanceControlPlane
    nor createGuidanceHooks() provides access to them.

    This means the question 'should we use ControlPlane or individual modules'
    is a false dichotomy. Even if we used ControlPlane, we would STILL need
    to individually instantiate all the modules ControlPlane doesn't cover.
    ControlPlane only handles 6 of 32 modules.""" .
