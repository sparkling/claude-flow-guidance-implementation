{
  "name": "@sparkleideas/claude-flow-guidance",
  "version": "3.0.0-alpha.1.wrapper.6",
  "description": "Implementation kit for wiring @claude-flow/guidance into Claude Code and Codex repos with hook automation",
  "type": "module",
  "private": false,
  "license": "MIT",
  "author": "Sparkling Ideas <henrik@sparklingideas.co.uk>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sparkling/claude-flow-guidance-implementation.git"
  },
  "homepage": "https://sparklingideas.co.uk/guidance/claude-flow",
  "bugs": {
    "url": "https://github.com/sparkling/claude-flow-guidance-implementation/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./src/installer.mjs"
    },
    "./installer": {
      "import": "./src/installer.mjs"
    },
    "./settings": {
      "import": "./src/default-settings.mjs"
    },
    "./runtime": {
      "import": "./src/guidance/advanced-runtime.js"
    },
    "./phase1": {
      "import": "./src/guidance/phase1-runtime.js"
    },
    "./executor": {
      "import": "./src/guidance/content-aware-executor.js"
    },
    "./enforcement": {
      "require": "./src/enforcement.cjs"
    },
    "./enforcement-layer": {
      "import": "./src/guidance/enforcement-layer.js"
    },
    "./embeddings": {
      "import": "./src/guidance/embedding-provider.js"
    },
    "./memory-gate": {
      "import": "./src/guidance/memory-write-gate.js"
    },
    "./observation": {
      "import": "./src/guidance/observation-layer.js"
    },
    "./validation": {
      "import": "./src/guidance/validation-layer.js"
    },
    "./knowledge": {
      "import": "./src/guidance/knowledge-layer.js"
    },
    "./infrastructure": {
      "import": "./src/guidance/infrastructure-layer.js"
    }
  },
  "files": [
    "bin",
    "src",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "cf-guidance": "bin/guidance.mjs",
    "cf-guidance-impl": "bin/guidance.mjs"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "node ./bin/guidance.mjs verify --target .",
    "swarm:init": "npx @claude-flow/cli@latest swarm init --topology hierarchical --max-agents 8 --strategy specialized",
    "swarm:route": "npx @claude-flow/cli@latest hooks route --task \"implement reusable guidance integration kit\"",
    "guidance:analyze": "cf-guidance analyze",
    "guidance:scaffold": "cf-guidance scaffold",
    "guidance:all": "cf-guidance run all",
    "guidance:status": "cf-guidance run status",
    "guidance:hooks": "cf-guidance run hooks",
    "guidance:trust": "cf-guidance run trust",
    "guidance:proof": "cf-guidance run proof",
    "guidance:runtime": "cf-guidance runtime demo",
    "guidance:compliance": "node scripts/run-compliance.js",
    "guidance:compliance:json": "node scripts/run-compliance.js --json"
  },
  "dependencies": {
    "@claude-flow/guidance": "^3.0.0-alpha.1",
    "@claude-flow/hooks": "^3.0.0-alpha.7"
  },
  "keywords": [
    "claude-flow",
    "guidance",
    "agentic",
    "claude-md",
    "codex",
    "control-plane",
    "hook-handler",
    "hooks",
    "claude-code",
    "automation",
    "autopilot"
  ],
  "packageManager": "npm@10",
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "vitest": "^4.0.18"
  }
}
