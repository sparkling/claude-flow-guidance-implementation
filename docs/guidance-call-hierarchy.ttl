@prefix gcfg: <urn:claude-flow:guidance:> .
@prefix mod:  <urn:claude-flow:guidance:module:> .
@prefix wrap: <urn:claude-flow:wrapper:> .
@prefix cp:   <urn:claude-flow:guidance:control-plane:> .
@prefix hook: <urn:claude-flow:guidance:hooks:> .
@prefix fact: <urn:claude-flow:guidance:factory:> .
@prefix cls:  <urn:claude-flow:guidance:class:> .
@prefix meth: <urn:claude-flow:guidance:method:> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# ============================================================================
# ONTOLOGY: Call Hierarchy for @claude-flow/guidance and our wrapper
# ============================================================================
#
# This document traces the actual call hierarchy of the upstream
# @claude-flow/guidance package (32 modules) and our wrapper
# @sparkleideas/claude-flow-guidance, based on source-level analysis.
#
# Source: github.com/ruvnet/claude-flow/tree/main/v3/@claude-flow/guidance/src
# Wrapper: /home/claude/src/claude-flow-guidance-implementation/
# Date: 2026-02-24
# ============================================================================

# --- Properties -----------------------------------------------------------

gcfg:importsModule     rdfs:label "imports module" ;
                       rdfs:comment "Subject imports the object module" .
gcfg:instantiates      rdfs:label "instantiates" ;
                       rdfs:comment "Subject creates an instance of object factory/class" .
gcfg:calls             rdfs:label "calls method" ;
                       rdfs:comment "Subject calls a method on object" .
gcfg:composes          rdfs:label "composes" ;
                       rdfs:comment "Subject holds an instance of object as internal field" .
gcfg:acceptsInjected   rdfs:label "accepts injected" ;
                       rdfs:comment "Subject receives object as constructor/factory parameter" .
gcfg:upstreamPhase     rdfs:label "upstream adoption phase" ;
                       rdfs:comment "Which upstream adoption phase this module belongs to" .
gcfg:usedByWrapper     rdfs:label "used by wrapper" ;
                       rdfs:comment "Whether our wrapper uses this module" .
gcfg:usedInFile        rdfs:label "used in file" ;
                       rdfs:comment "Which wrapper file uses this module" .
gcfg:exports           rdfs:label "exports" ;
                       rdfs:comment "Module exports this factory/class" .
gcfg:standaloneUsable  rdfs:label "standalone usable" ;
                       rdfs:comment "Can be used without GuidanceControlPlane" .

